{
	"info": {
		"_postman_id": "medibuddy-backend-api",
		"name": "MediBuddy API",
		"description": "MediBuddy REST API - A secure, mobile-first health management app that helps users track medications, log symptoms, prepare consultation summaries, and support caregivers with privacy-focused tools.\n\n## Getting Started\n\n1. **Set `baseUrl`** to your running server (default: `http://localhost:3000/api`).\n2. **Request an OTP** via `Auth > Request OTP`.\n3. **Verify OTP** via `Auth > Verify OTP` — the access and refresh tokens are saved automatically.\n4. **Create a Profile** — the `profileId` is saved automatically.\n5. All authenticated requests inherit the Bearer token from the collection.\n\n## Variables\n\n| Variable | Description |\n|----------|-------------|\n| `baseUrl` | API base URL (default `http://localhost:3000/api`) |\n| `accessToken` | JWT access token (auto-set by Verify OTP) |\n| `refreshToken` | JWT refresh token (auto-set by Verify OTP) |\n| `profileId` | Current profile ID (auto-set by Create Profile) |\n| `medId` | Current medication ID (auto-set by Create Medication) |\n| `reminderId` | A reminder event ID |\n| `summaryId` | A summary ID (auto-set by Generate Summary) |\n| `caregiverId` | A caregiver ID (auto-set by Add Caregiver) |\n| `appointmentId` | An appointment ID (auto-set by Create Appointment) |\n| `metricId` | A health metric ID (auto-set by Add Health Metric) |\n| `conversationId` | A conversation ID |\n| `messageId` | A message ID |\n| `recipientId` | User ID of message recipient |\n| `phone` | Test phone number |",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:3000/api", "type": "string" },
		{ "key": "accessToken", "value": "", "type": "string" },
		{ "key": "refreshToken", "value": "", "type": "string" },
		{ "key": "profileId", "value": "", "type": "string" },
		{ "key": "medId", "value": "", "type": "string" },
		{ "key": "reminderId", "value": "", "type": "string" },
		{ "key": "summaryId", "value": "", "type": "string" },
		{ "key": "caregiverId", "value": "", "type": "string" },
		{ "key": "appointmentId", "value": "", "type": "string" },
		{ "key": "metricId", "value": "", "type": "string" },
		{ "key": "conversationId", "value": "", "type": "string" },
		{ "key": "messageId", "value": "", "type": "string" },
		{ "key": "recipientId", "value": "", "type": "string" },
		{ "key": "phone", "value": "+2348012345678", "type": "string" },
		{ "key": "requestId", "value": "", "type": "string" }
	],
	"item": [
		{
			"name": "Health",
			"description": "System health check endpoint. No authentication required.",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "Returns system health status including MongoDB connection, Redis connection, and server uptime."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Health check returns success', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.be.true;",
									"    pm.expect(json.data.status).to.eql('ok');",
									"});"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "Auth",
			"description": "Authentication endpoints: OTP-based phone auth, token refresh, consent, and account deletion.\n\nFlow: Request OTP → Verify OTP → Use access token for all other requests.",
			"item": [
				{
					"name": "Request OTP",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"{{phone}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/otp",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "otp"]
						},
						"auth": { "type": "noauth" },
						"description": "Request a 6-digit OTP for phone verification. Rate limited to 5 requests per 10 minutes.\n\nIn development mode, the OTP is logged to the server console."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('OTP requested successfully', function () {",
									"    pm.response.to.have.status(200);",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.be.true;",
									"    if (json.data && json.data.requestId) {",
									"        pm.collectionVariables.set('requestId', json.data.requestId);",
									"    }",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Verify OTP",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"requestId\": \"{{requestId}}\",\n  \"otp\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/verify",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "verify"]
						},
						"auth": { "type": "noauth" },
						"description": "Verify the 6-digit OTP. Returns JWT access token (15 min) and refresh token (30 days).\n\nReplace the `otp` value with the code from the server console (dev mode)."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('OTP verified, tokens saved', function () {",
									"    pm.response.to.have.status(200);",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.be.true;",
									"    if (json.data) {",
									"        pm.collectionVariables.set('accessToken', json.data.accessToken);",
									"        pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
									"    }",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "refresh"]
						},
						"auth": { "type": "noauth" },
						"description": "Exchange a valid refresh token for a new access token."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Token refreshed', function () {",
									"    pm.response.to.have.status(200);",
									"    const json = pm.response.json();",
									"    if (json.data && json.data.accessToken) {",
									"        pm.collectionVariables.set('accessToken', json.data.accessToken);",
									"    }",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "logout"]
						},
						"description": "Revoke the current refresh token. Auth header is optional but recommended."
					},
					"response": []
				},
				{
					"name": "Update Consent",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"accepted\": true,\n  \"version\": \"1.0\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/consent",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "consent"]
						},
						"description": "Record user consent acceptance with a version string."
					},
					"response": []
				},
				{
					"name": "Delete Account",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/auth/account",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "account"]
						},
						"description": "Soft-delete the authenticated user's account. 30-day grace period before permanent deletion."
					},
					"response": []
				}
			]
		},
		{
			"name": "Profiles",
			"description": "Patient/family member profiles. Each user can have multiple profiles (self, family members).",
			"item": [
				{
					"name": "List Profiles",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profiles",
							"host": ["{{baseUrl}}"],
							"path": ["profiles"]
						},
						"description": "List all profiles owned by the authenticated user."
					},
					"response": []
				},
				{
					"name": "Create Profile",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Idempotency-Key", "value": "{{$guid}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Doe\",\n  \"dob\": \"1990-06-15T00:00:00.000Z\",\n  \"relation\": \"self\",\n  \"conditions\": [\"hypertension\", \"diabetes\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profiles",
							"host": ["{{baseUrl}}"],
							"path": ["profiles"]
						},
						"description": "Create a new profile.\n\n**relation**: `self`, `family`, or `other` (default: `self`).\n\n**Idempotency-Key** header prevents duplicate creation on retries."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Profile created', function () {",
									"    const status = pm.response.code;",
									"    pm.expect([200, 201]).to.include(status);",
									"    const json = pm.response.json();",
									"    if (json.data && json.data._id) {",
									"        pm.collectionVariables.set('profileId', json.data._id);",
									"    }",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}"]
						},
						"description": "Get a specific profile by ID."
					},
					"response": []
				},
				{
					"name": "Update Profile",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Doe Updated\",\n  \"conditions\": [\"hypertension\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}"]
						},
						"description": "Update a profile. All fields are optional."
					},
					"response": []
				},
				{
					"name": "Delete Profile",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}"]
						},
						"description": "Soft-delete a profile."
					},
					"response": []
				}
			]
		},
		{
			"name": "Medications",
			"description": "Medication management for a profile. Creating or updating a medication automatically schedules/reschedules reminder jobs.",
			"item": [
				{
					"name": "List Medications",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/medications",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "medications"]
						},
						"description": "List all active (non-deleted) medications for a profile."
					},
					"response": []
				},
				{
					"name": "Create Medication",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Idempotency-Key", "value": "{{$guid}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Metformin\",\n  \"dosage\": \"500mg\",\n  \"times\": [\"08:00\", \"20:00\"],\n  \"timezone\": \"Africa/Lagos\",\n  \"channels\": [\"push\"],\n  \"startDate\": \"2026-02-13T00:00:00.000Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/medications",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "medications"]
						},
						"description": "Create a medication and schedule reminder jobs.\n\n**times**: Array of `HH:mm` strings.\n**timezone**: IANA timezone (default: `Africa/Lagos`).\n**channels**: `push` and/or `sms`."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Medication created', function () {",
									"    const status = pm.response.code;",
									"    pm.expect([200, 201]).to.include(status);",
									"    const json = pm.response.json();",
									"    if (json.data && json.data._id) {",
									"        pm.collectionVariables.set('medId', json.data._id);",
									"    }",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Get Medication",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/medications/{{medId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "medications", "{{medId}}"]
						},
						"description": "Get a single medication by ID."
					},
					"response": []
				},
				{
					"name": "Update Medication",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"dosage\": \"1000mg\",\n  \"times\": [\"08:00\", \"14:00\", \"20:00\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/medications/{{medId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "medications", "{{medId}}"]
						},
						"description": "Update a medication. Reminders are cancelled and rescheduled automatically."
					},
					"response": []
				},
				{
					"name": "Delete Medication",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/medications/{{medId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "medications", "{{medId}}"]
						},
						"description": "Soft-delete a medication and cancel its scheduled reminders."
					},
					"response": []
				}
			]
		},
		{
			"name": "Symptoms",
			"description": "Symptom logging for a profile. Supports date range filtering and pagination.",
			"item": [
				{
					"name": "List Symptoms",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/symptoms?limit=50&offset=0",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "symptoms"],
							"query": [
								{ "key": "limit", "value": "50", "description": "Max results (1-100, default: 50)" },
								{ "key": "offset", "value": "0", "description": "Skip N results (default: 0)" },
								{ "key": "start", "value": "", "description": "ISO 8601 start date filter", "disabled": true },
								{ "key": "end", "value": "", "description": "ISO 8601 end date filter", "disabled": true }
							]
						},
						"description": "List symptom logs for a profile with optional date range filtering and pagination."
					},
					"response": []
				},
				{
					"name": "Log Symptom",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Idempotency-Key", "value": "{{$guid}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"symptom\": \"Headache\",\n  \"severity\": 3,\n  \"duration\": \"2 hours\",\n  \"notes\": \"Started after lunch, mild throbbing pain\",\n  \"clientTs\": \"2026-02-13T14:30:00.000Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/symptoms",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "symptoms"]
						},
						"description": "Log a new symptom.\n\n**severity**: 1 (mild) to 5 (severe).\n**clientTs**: Required ISO 8601 timestamp from the client."
					},
					"response": []
				}
			]
		},
		{
			"name": "Reminders",
			"description": "Medication reminder events. Reminders are created automatically by the job scheduler. Clients acknowledge them via the ack endpoint.",
			"item": [
				{
					"name": "List Reminders",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/reminders",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "reminders"]
						},
						"description": "List reminder events for a profile (24 hours ago through 24 hours ahead). Includes medication details."
					},
					"response": []
				},
				{
					"name": "Acknowledge Reminder",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Idempotency-Key", "value": "{{$guid}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"action\": \"taken\",\n  \"deviceId\": \"device-001\",\n  \"clientTs\": \"2026-02-13T08:05:00.000Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/reminders/{{reminderId}}/ack",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "reminders", "{{reminderId}}", "ack"]
						},
						"description": "Acknowledge a reminder event.\n\n**action**: `taken`, `snooze`, or `skip`."
					},
					"response": []
				}
			]
		},
		{
			"name": "Summaries",
			"description": "Consultation summaries with PDF generation. Aggregates medications, symptoms, and adherence data for a date range.",
			"item": [
				{
					"name": "Generate Summary",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"startDate\": \"2026-01-01T00:00:00.000Z\",\n  \"endDate\": \"2026-02-13T23:59:59.000Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/summaries",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "summaries"]
						},
						"description": "Generate a consultation summary PDF for the given date range. Returns metadata with a download URL."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Summary generated', function () {",
									"    const status = pm.response.code;",
									"    pm.expect([200, 201]).to.include(status);",
									"    const json = pm.response.json();",
									"    if (json.data && json.data.id) {",
									"        pm.collectionVariables.set('summaryId', json.data.id);",
									"    }",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "List Summaries",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/summaries",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "summaries"]
						},
						"description": "List all consultation summaries for a profile."
					},
					"response": []
				},
				{
					"name": "Get Summary",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profiles/{{profileId}}/summaries/{{summaryId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{profileId}}", "summaries", "{{summaryId}}"]
						},
						"description": "Get a specific summary by ID."
					},
					"response": []
				},
				{
					"name": "Download Summary PDF",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
